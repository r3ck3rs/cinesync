# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed for server-side admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TMDB API — get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
NEXT_PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# App URL (change in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
